{
    "version": 2,
    "functions": {
        "backend/api/index.py": {
            "runtime": "vercel-python@3.12.0"
        }
    },
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "backend/api/index.py"
        },
        {
            "src": "/(.*)",
            "dest": "frontend/$1"
        }
    ]
}