{
    "version": 2,
    "builds": [
        {
            "src": "backend/api/index.py",
            "use": "@vercel/python"
        },
        {
            "src": "frontend/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/register",
            "dest": "backend/api/index.py"
        },
        {
            "src": "/api/login",
            "dest": "backend/api/index.py"
        },
        {
            "src": "/api/users",
            "dest": "backend/api/index.py"
        },
        {
            "src": "/api/reset_password",
            "dest": "backend/api/index.py"
        },
        {
            "src": "/(.*)",
            "dest": "frontend/$1"
        },
        {
            "src": "/",
            "dest": "frontend/index.html"
        }
    ]
}